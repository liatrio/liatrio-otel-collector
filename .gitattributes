# Mark generated files so GitHub collapses them in diffs and excludes them
# from language statistics. These are all regenerated by `make generate`
# (mdatagen / genqlient) and should never be hand-edited.
**/internal/metadata/generated_*.go linguist-generated=true
**/internal/metadata/testdata/config.yaml linguist-generated=true
**/documentation.md linguist-generated=true
**/generated_graphql.go linguist-generated=true
